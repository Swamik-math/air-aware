# Backend
DATABASE_URL=sqlite:///airaware.db
AQI_API_TOKEN=
AQI_API_URL=https://api.waqi.info/feed/geo:{lat};{lon}/
SECRET_KEY=airaware-dev-key
MAPPLS_API_KEY=
MAPPLS_ROUTE_URL_TEMPLATE=https://apis.mappls.com/advancedmaps/v1/{api_key}/route_adv/driving/{origin};{destination}

# Frontend
VITE_API_BASE_URL=http://localhost:5000
VITE_MAP_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}
